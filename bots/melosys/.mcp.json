{
  "mcpServers": {
    "knowledge": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "--directory",
        "/Users/rune/source/private/documents-vector-search",
        "run",
        "knowledge_api_mcp_adapter.py"
      ],
      "env": {
        "KNOWLEDGE_API_URL": "http://localhost:8321",
        "KNOWLEDGE_COLLECTIONS": "melosys-confluence-v3,jira-issues",
        "KNOWLEDGE_DESCRIPTION": "Melosys/NAV technical documentation — EU/EEA social security coordination (trygdekoordinering), EESSI BUCs and SEDs, regulations 883/2004 and 987/2009, folketrygdloven, architecture and development guides and Jira issues"
      }
    },
    "serena-api": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "claude-code",
        "--project",
        "/Users/rune/source/nav/melosys-api",
        "--open-web-dashboard",
        "False"
      ]
    },
    "serena-web": {
