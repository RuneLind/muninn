# ============================================================
# Production — real Telegram/Slack bots, scheduler, voice
# ============================================================

# Per-bot tokens (one pair per bot folder in bots/<name>/)
TELEGRAM_BOT_TOKEN_JARVIS=your-jarvis-bot-token
TELEGRAM_ALLOWED_USER_IDS_JARVIS=123456789
# TELEGRAM_BOT_TOKEN_CAPRA=your-capra-bot-token
# TELEGRAM_ALLOWED_USER_IDS_CAPRA=123456789

# Slack (optional — per bot, needs both tokens)
# SLACK_BOT_TOKEN_JARVIS=xoxb-...
# SLACK_APP_TOKEN_JARVIS=xapp-...
# SLACK_ALLOWED_USER_IDS_JARVIS=U12345678

# Database (shared by all bots)
DATABASE_URL=postgresql://javrvis:javrvis@127.0.0.1:5434/javrvis

# Dashboard
DASHBOARD_PORT=3010

# Claude
CLAUDE_MODEL=sonnet
CLAUDE_TIMEOUT_MS=120000

# Scheduler (tasks, goal reminders, watchers)
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MS=60000

# Voice (macOS only)
WHISPER_MODEL_PATH=./models/ggml-base.en.bin

# Tracing
# TRACING_ENABLED=true
# TRACING_RETENTION_DAYS=7
# PROMPT_SNAPSHOTS_RETENTION_DAYS=3
