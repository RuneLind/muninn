bots/*/specs/

# Benchmark data (manifests, golds, calibration, plan docs)
# Sensitive — references real Jira issues. Source code lives in src/benchmarks/.
# Root-anchored so this only matches top-level benchmarks/, not src/benchmarks/.
/benchmarks/

# Chat config (contains user IDs)
chat.config.json

# Finder (MacOS) folder config
.DS_Store

# Working / scratch docs belong in the mimir wiki repo, not here.
# See ../mimir/plans/consolidate-working-docs-into-mimir.md for the policy.
# muninn/docs/ keeps zero working docs after Phase 4 cleanup; docs/examples/ stays.
docs/*.md
docs/*.html
docs/*.excalidraw
/PLAN.md
/We*.md
/parallel-*.md
/Vipps*.md

# Local-only Claude Code memory (private LLM-session redirect to mimir wiki repo)
CLAUDE.local.md

# Local probe / investigation outputs (logs, JSONL, status HTML).
